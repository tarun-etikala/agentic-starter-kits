# Agentic Starter Kits — Environment Configuration
#
# Copy this file to .env and fill in your values.
# Used by agentctl for Helm-based deployments and by agents for local dev.
#
# For local development, you can also use per-agent template.env files
# located in each agent directory (e.g. agents/langgraph/react_agent/template.env).

# ── Required ──────────────────────────────────────────────────────────
# API key for the model serving endpoint
API_KEY=

# Base URL for the OpenAI-compatible API endpoint
BASE_URL=

# Model identifier (e.g. llama-31-8b-instruct, gpt-4o)
MODEL_ID=

# ── Container Image (for deployment) ─────────────────────────────────
# Full image reference for building/pushing (e.g. quay.io/team/my-agent:v1)
CONTAINER_IMAGE=

# ── RAG-specific (only for langgraph/agentic_rag) ────────────────────
# EMBEDDING_MODEL=
# VECTOR_STORE_NAME=
# VECTOR_STORE_ID=
