# OpenAI-compatible LLM (e.g. Llama Stack) — used by BOTH agents.
# Must end with /v1 for chat/completions (langgraph server also auto-appends /v1 if missing).
BASE_URL=http://127.0.0.1:8321/v1
MODEL_ID=meta-llama/Llama-3.2-3B-Instruct
API_KEY=no-key

# A2A: public URL embedded in Agent Card (must match how clients reach the Crew server)
CREW_A2A_PUBLIC_URL=http://127.0.0.1:9100
LANGGRAPH_A2A_PUBLIC_URL=http://127.0.0.1:9200

# Orchestrator → Crew specialist (JSON-RPC base, no trailing path — same host as CREW_A2A_PUBLIC_URL)
CREW_A2A_URL=http://127.0.0.1:9100

# Ports (optional overrides)
CREW_A2A_PORT=9100
LANGGRAPH_A2A_PORT=9200
