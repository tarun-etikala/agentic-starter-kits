# Required — LLM Configuration
API_KEY=
BASE_URL=
MODEL_ID=

# Deployment — Agent
CONTAINER_IMAGE=

# MCP Server URL (local default; OpenShift deploy uses in-cluster DNS automatically)
MCP_SERVER_URL=http://127.0.0.1:8000/sse

# MCP Server — DNS rebinding protection (enabled by default in MCP SDK ≥1.x)
# Disabled by default for starter-kit convenience (OpenShift Route host is unknown until deploy).
# For production, set to false and configure ALLOWED_HOSTS instead:
# ALLOWED_HOSTS=myapp.apps.cluster.example.com
DISABLE_DNS_REBINDING_PROTECTION=true

# MCP AutoML Server Deployment (only needed for `make deploy-mcp`)
# CONTAINER_IMAGE_MCP=
# DEPLOYMENT_URL=
# DEPLOYMENT_TOKEN=
