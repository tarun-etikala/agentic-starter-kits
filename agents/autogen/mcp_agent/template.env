# Deployment (used by MCP tools: deployment_url_env / deployment_token_env in tools_config.yaml)
# DEPLOYMENT_URL=
# DEPLOYMENT_TOKEN=
# CONTAINER_IMAGE_MCP=
# DISABLE_DNS_REBINDING_PROTECTION=true

# Agent specific variables
# API_KEY=
# BASE_URL=
# MODEL_ID=
# CONTAINER_IMAGE=
#
# Local Ollama (OpenAI-compatible), example:
# API_KEY=ollama
# BASE_URL=http://localhost:11434/v1
# MODEL_ID=llama3.2

# Optional: override MCP URL (OpenShift deploy defaults to http://mcp-automl:8080/sse)
# MCP_SERVER_URL=http://127.0.0.1:8000/sse
