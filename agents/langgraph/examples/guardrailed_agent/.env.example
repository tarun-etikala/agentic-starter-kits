# Required — agent connects to NeMo Guardrails proxy, not directly to the LLM
API_KEY=not-needed-for-local-development
BASE_URL=http://localhost:8090/v1
MODEL_ID=llama3.1:8b

# NeMo Guardrails — the proxy server that sits between the agent and the LLM
# Start with: make guardrails-server
# The guardrails server config is in guardrails/safety/config.yaml
# GUARDRAILS_PORT=8090
# LLM_BASE_URL=http://localhost:11434/v1

# Deployment
#CONTAINER_IMAGE=

# Auth (local default off; comma-separate multiple allowlist entries)
# AUTH_ENABLED=false
# AUTH_AUDIENCE=langgraph-guardrailed-agent
# AUTH_ALLOWED_SERVICEACCOUNTS=ci-testing:langgraph-guardrailed-agent-caller

# Optional — MLflow Tracing
# Tracing is opt-in: if MLFLOW_TRACKING_URI is not set, the agent runs without MLflow.
# Note: MLflow traces show the overall request but not guardrails internals.
# NeMo Guardrails appears as a regular ChatOpenAI endpoint in MLflow.

# --- Local MLflow server (no auth, no TLS) ---
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_EXPERIMENT_NAME=langgraph-guardrailed-agent
