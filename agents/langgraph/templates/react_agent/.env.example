# Required
API_KEY=not-needed-for-local-development
BASE_URL=http://localhost:8321/v1
MODEL_ID=ollama/Llama3.1:8B

# Deployment
#CONTAINER_IMAGE=

# Auth (local default off; comma-separate multiple allowlist entries)
# AUTH_ENABLED=false
# AUTH_AUDIENCE=langgraph-react-agent
# AUTH_ALLOWED_SERVICEACCOUNTS=ci-testing:langgraph-react-agent-caller

# Optional — MLflow Tracing
# Tracing is opt-in: if MLFLOW_TRACKING_URI is not set, the agent runs without MLflow.
# For TLS and auth details, see docs/mlflow-openshift-auth-and-tls.md

# --- Local MLflow server (no auth, no TLS) ---
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_EXPERIMENT_NAME=langgraph-react-agent
# MLFLOW_HEALTH_CHECK_TIMEOUT=5
# MLFLOW_HTTP_REQUEST_TIMEOUT=2
# MLFLOW_HTTP_REQUEST_MAX_RETRIES=0

# --- OpenShift MLflow from locally running agent app ---
# MLFLOW_TRACKING_URI=https://mlflow-redhat-ods-applications.apps.<cluster>/mlflow
# MLFLOW_EXPERIMENT_NAME=langgraph-react-agent
# MLFLOW_TRACKING_TOKEN=<paste token from: oc create token default>
# MLFLOW_WORKSPACE=<namespace>

# --- OpenShift MLflow from pod ---
# MLFLOW_TRACKING_URI=https://mlflow.redhat-ods-applications.svc:8443/mlflow
# MLFLOW_EXPERIMENT_NAME=langgraph-react-agent
# MLFLOW_TRACKING_AUTH=kubernetes-namespaced
# MLFLOW_TRACKING_SERVER_CERT_PATH=/var/run/secrets/kubernetes.io/serviceaccount/service-ca.crt
